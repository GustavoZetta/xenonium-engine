{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "Linux-GCC-Debug",
      "displayName": "Linux GCC Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/Linux-GCC-Debug",
      "installDir": "${sourceDir}/out/install/Linux-GCC-Debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "/usr/bin/gcc",
        "CMAKE_CXX_COMPILER": "/usr/bin/g++"
      }
    },
    {
      "name": "Linux-GCC-Release",
      "displayName": "Linux GCC Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/Linux-GCC-Release",
      "installDir": "${sourceDir}/out/install/Linux-GCC-Release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_C_COMPILER": "/usr/bin/gcc",
        "CMAKE_CXX_COMPILER": "/usr/bin/g++"
      }
    },
    {
      "name": "Mingw64-Debug",
      "displayName": "MinGW64 Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/Mingw64-Debug",
      "installDir": "${sourceDir}/out/install/Mingw64-Debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "$env{MINGW64_BIN}/gcc.exe",
        "CMAKE_CXX_COMPILER": "$env{MINGW64_BIN}/g++.exe"
      },
      "environment": {
        "MSYS64_ROOT": "C:/msys64",
        "MINGW64_ROOT": "$env{MSYS64_ROOT}/ucrt64",
        "MINGW64_BIN": "$env{MINGW64_ROOT}/bin",
        "PATH": "$env{MINGW64_BIN};$env{MSYS64_ROOT}/usr/local/bin;$env{MSYS64_ROOT}/usr/bin;$env{MSYS64_ROOT}/bin;$penv{PATH}"
      }
    },
    {
      "name": "Mingw64-Release",
      "displayName": "MinGW64 Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/Mingw64-Release",
      "installDir": "${sourceDir}/out/install/Mingw64-Release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_C_COMPILER": "$env{MINGW64_BIN}/gcc.exe",
        "CMAKE_CXX_COMPILER": "$env{MINGW64_BIN}/g++.exe"
      },
      "environment": {
        "MSYS64_ROOT": "C:/msys64",
        "MINGW64_ROOT": "$env{MSYS64_ROOT}/ucrt64",
        "MINGW64_BIN": "$env{MINGW64_ROOT}/bin",
        "PATH": "$env{MINGW64_BIN};$env{MSYS64_ROOT}/usr/local/bin;$env{MSYS64_ROOT}/usr/bin;$env{MSYS64_ROOT}/bin;$penv{PATH}"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "Linux-GCC-Debug",
      "configurePreset": "Linux-GCC-Debug",
      "verbose": true
    },
    {
      "name": "Linux-GCC-Release",
      "configurePreset": "Linux-GCC-Release",
      "verbose": true
    },
    {
      "name": "Mingw64-Debug",
      "configurePreset": "Mingw64-Debug",
      "verbose": true
    },
    {
      "name": "Mingw64-Release",
      "configurePreset": "Mingw64-Release",
      "verbose": true
    }
  ]
}